# Editors
.idea
.vscode/
.DS_Store

# Local terraform directories
**/.terraform/

# Local terragrunt directories
**/.terragrunt-cache/

# State files
*.tfstate
*.tfstate.*

# Plan files
*.tfplan

# Crash logs
crash.log
crash.*.log

# Variable files (may contain secrets — allowlist explicitly with !name.tfvars)
*.tfvars
*.tfvars.json

# Override files (local-only)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Environment files
.env
.env.*
